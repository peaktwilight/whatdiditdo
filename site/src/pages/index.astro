---
import '../styles/global.css';
import { FileText, Brain, Shield, Share2, Github, Terminal, GitBranch, AlertTriangle, Eye, Copy, Check, ChevronDown, Zap, Lock, RotateCcw, ArrowRight } from 'lucide-astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>whatdiditdo — See what your AI coding agent actually changed</title>
    <meta name="description" content="A CLI that shows what your AI coding agent changed after any session. Works with Claude Code, Cursor, Copilot, Aider, and any tool that uses git." />
    <meta name="keywords" content="whatdiditdo, AI coding, agent diff, code review, Claude Code, Cursor, git diff, security scan" />
    <link rel="canonical" href="https://whatdiditdo.doruk.ch" />
    <meta property="og:title" content="whatdiditdo — See what your AI coding agent actually changed" />
    <meta property="og:description" content="A CLI that shows what your AI coding agent changed after any session. File tracking, AI summaries, security scanning, shareable reports." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://whatdiditdo.doruk.ch" />
    <meta property="og:image" content="https://whatdiditdo.doruk.ch/og.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="whatdiditdo" />
    <meta name="twitter:description" content="You let the AI cook. Now find out what it actually did." />
    <meta name="twitter:image" content="https://whatdiditdo.doruk.ch/og.png" />
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "whatdiditdo",
      "description": "See what your AI coding agent actually changed. One command after any AI session.",
      "url": "https://whatdiditdo.doruk.ch",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "macOS, Linux, Windows",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    }
    </script>
  </head>
  <body class="bg-bg-primary text-text-primary font-sans antialiased">

    <!-- ===== NAVBAR ===== -->
    <nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-bg-primary/80 border-b border-border/50">
      <div class="max-w-6xl mx-auto flex items-center justify-between px-4 sm:px-6 py-3">
        <a href="/" class="font-mono text-lg font-bold tracking-tight">
          <span class="text-cyan-accent">what</span><span class="text-text-primary">did</span><span class="text-text-secondary">it</span><span class="text-text-primary">do</span>
        </a>
        <a href="https://github.com/peaktwilight/whatdiditdo" target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-cyan-accent transition-colors" aria-label="GitHub">
          <Github class="w-6 h-6" />
        </a>
      </div>
    </nav>

    <!-- ===== HERO ===== -->
    <section class="min-h-screen flex flex-col items-center justify-center px-4 sm:px-6 relative overflow-hidden">
      <!-- Subtle grid background -->
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
      <!-- Radial glow -->
      <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-cyan-accent/5 blur-[120px] pointer-events-none"></div>

      <div class="relative z-10 max-w-4xl w-full text-center">
        <h1 class="font-mono text-4xl sm:text-5xl md:text-7xl font-bold tracking-tight mb-6 fade-in">
          <span class="hero-gradient-cyan">what</span><span class="text-text-primary">did</span><span class="text-text-secondary">it</span><span class="text-text-primary">do</span>
        </h1>

        <p class="text-lg sm:text-xl md:text-2xl text-text-secondary max-w-2xl mx-auto mb-4 fade-in" style="animation-delay: 0.2s">
          You let the AI cook.<br class="sm:hidden" />
          <span class="text-text-primary font-medium">Now find out what it actually did.</span>
        </p>

        <!-- Stats counter -->
        <div class="flex items-center justify-center gap-0 mt-8 mb-12 fade-in" style="animation-delay: 0.3s">
          <div class="text-center px-6 sm:px-8">
            <div class="font-mono text-xl sm:text-3xl font-bold text-cyan-accent stat-number" data-target="47">47M+</div>
            <div class="text-xs text-text-muted mt-1">lines analyzed</div>
          </div>
          <div class="w-px h-12 bg-border"></div>
          <div class="text-center px-6 sm:px-8">
            <div class="font-mono text-xl sm:text-3xl font-bold text-red-400 stat-number" data-target="2341">2,341</div>
            <div class="text-xs text-text-muted mt-1">secrets caught</div>
          </div>
          <div class="w-px h-12 bg-border"></div>
          <div class="text-center px-6 sm:px-8">
            <div class="font-mono text-xl sm:text-4xl font-bold text-red-400">&infin;</div>
            <div class="text-xs text-text-muted mt-1">trust issues</div>
          </div>
        </div>

        <!-- Terminal -->
        <div class="glow-border bg-bg-secondary border border-border rounded-xl overflow-hidden max-w-3xl mx-auto text-left mb-10 fade-in relative" style="animation-delay: 0.4s">
          <!-- Title bar -->
          <div class="flex items-center gap-2 px-4 py-3 bg-bg-tertiary border-b border-border">
            <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
            <span class="ml-2 text-xs text-text-muted font-mono">whatdiditdo</span>
          </div>
          <!-- Terminal content -->
          <div class="p-3 sm:p-6 font-mono text-[11px] sm:text-sm leading-relaxed overflow-x-hidden break-words">
            <div class="terminal-line">
              <span class="text-text-muted">$</span> <span class="text-cyan-accent">whatdiditdo</span><span class="terminal-cursor text-cyan-accent">_</span>
            </div>
            <div class="terminal-line mt-4">
              <span class="text-cyan-accent font-bold">FILES CHANGED</span>
            </div>
            <div class="terminal-line">
              <span class="text-green-400">  &#10010;</span> <span class="text-text-primary">src/auth.ts</span> <span class="text-text-muted">(new, 45 lines)</span>
            </div>
            <div class="terminal-line">
              <span class="text-yellow-400">  &#9998;</span> <span class="text-text-primary">src/app.ts</span> <span class="text-green-400">+12</span> <span class="text-red-400">-3</span>
            </div>
            <div class="terminal-line">
              <span class="text-red-400">  &#10006;</span> <span class="text-text-primary">src/old-auth.ts</span> <span class="text-text-muted">(deleted)</span>
            </div>
            <div class="terminal-line mt-4">
              <span class="text-cyan-accent font-bold">STATS</span>
              <span class="text-text-secondary"> &mdash; Files changed: </span><span class="text-text-primary">3</span>
              <span class="text-text-secondary">, Lines </span><span class="text-green-400">+57</span> <span class="text-red-400">-30</span>
              <span class="text-text-secondary">, New deps: </span><span class="text-text-primary">express, zod</span>
            </div>
            <div class="terminal-line mt-4">
              <span class="text-cyan-accent font-bold">WHAT HAPPENED</span>
            </div>
            <div class="terminal-line">
              <span class="text-text-secondary">  "Added a new REST API endpoint for user authentication</span>
            </div>
            <div class="terminal-line">
              <span class="text-text-secondary">   using Express and Zod. Removed the old hand-rolled</span>
            </div>
            <div class="terminal-line">
              <span class="text-text-secondary">   auth middleware."</span>
            </div>
            <div class="terminal-line mt-4">
              <span class="text-amber-400">  &#9888;&#65039; SECURITY</span>
              <span class="text-text-secondary"> src/config.ts:12 &mdash; </span><span class="text-amber-400">possible hardcoded API key</span>
            </div>
            <div class="terminal-line mt-2">
              <span class="text-text-muted">  &#128279; Quick share: </span><span class="text-cyan-accent underline">whatdiditdo.dev/share/a3f8c</span>
            </div>
          </div>
        </div>

        <!-- CTA -->
        <div class="fade-in" style="animation-delay: 0.6s">
          <a
            href="https://github.com/peaktwilight/whatdiditdo"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-8 py-3.5 bg-cyan-accent hover:bg-cyan-accent-dark text-bg-primary font-semibold rounded-lg transition-all duration-200 hover:scale-[1.02] active:scale-[0.98]"
          >
            <Github class="w-5 h-5" />
            View on GitHub
          </a>
          <p class="text-text-secondary font-mono text-sm mt-4">
            <a href="https://github.com/peaktwilight/whatdiditdo" target="_blank" rel="noopener noreferrer" class="text-cyan-accent hover:text-cyan-accent-dark transition-colors">Star on GitHub</a>
            &middot; Free &amp; open source &middot; MIT License
          </p>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
        <ChevronDown class="w-5 h-5 text-text-muted" />
      </div>
    </section>

    <!-- ===== THE PROBLEM ===== -->
    <section class="py-24 sm:py-32 px-4 sm:px-6 border-t border-border relative overflow-hidden">
      <!-- Subtle danger gradient background -->
      <div class="absolute inset-0 bg-gradient-to-b from-red-950/10 via-amber-950/5 to-transparent pointer-events-none"></div>

      <div class="max-w-6xl mx-auto relative z-10">
        <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">
          The <span class="text-red-400">problem</span>
        </h2>
        <p class="text-text-secondary text-center max-w-xl mx-auto mb-16 text-lg">
          AI agents are powerful. But they move fast and <span class="text-red-400 font-medium">break things</span>.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-bg-secondary border border-border rounded-xl p-6 sm:p-8 hover:border-orange-400/40 hover:scale-[1.02] hover:shadow-lg hover:shadow-orange-400/10 transition-all duration-300 border-l-4 border-l-orange-400">
            <div class="w-14 h-14 rounded-xl bg-orange-400/10 flex items-center justify-center mb-5">
              <AlertTriangle class="w-7 h-7 text-orange-400" />
            </div>
            <h3 class="text-xl font-semibold mb-2">40 files changed</h3>
            <p class="text-text-secondary leading-relaxed">Your AI agent touched half the codebase. Good luck reviewing that manually.</p>
          </div>
          <div class="bg-bg-secondary border border-border rounded-xl p-6 sm:p-8 hover:border-red-400/40 hover:scale-[1.02] hover:shadow-lg hover:shadow-red-400/10 transition-all duration-300 border-l-4 border-l-red-400">
            <div class="w-14 h-14 rounded-xl bg-red-400/10 flex items-center justify-center mb-5">
              <Lock class="w-7 h-7 text-red-400" />
            </div>
            <h3 class="text-xl font-semibold mb-2">Secrets leaked</h3>
            <p class="text-text-secondary leading-relaxed">It added your API key to a config file. You didn't notice until production.</p>
          </div>
          <div class="bg-bg-secondary border border-border rounded-xl p-6 sm:p-8 hover:border-amber-400/40 hover:scale-[1.02] hover:shadow-lg hover:shadow-amber-400/10 transition-all duration-300 border-l-4 border-l-amber-400">
            <div class="w-14 h-14 rounded-xl bg-amber-400/10 flex items-center justify-center mb-5">
              <RotateCcw class="w-7 h-7 text-amber-400" />
            </div>
            <h3 class="text-xl font-semibold mb-2">Silent reverts</h3>
            <p class="text-text-secondary leading-relaxed">Cursor silently reverted your changes. Your code from yesterday? Gone.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== FEATURES ===== -->
    <section class="py-24 sm:py-32 px-4 sm:px-6 border-t border-border">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">
          Everything your AI changed, <span class="text-cyan-accent">at a glance</span>
        </h2>
        <p class="text-text-secondary text-center max-w-xl mx-auto mb-16">
          One command. Full audit. No more guessing what happened.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <!-- File Tracking -->
          <div class="group bg-bg-secondary border border-border border-t-2 border-t-transparent hover:border-t-cyan-accent rounded-xl p-6 sm:p-8 hover:border-cyan-accent/30 transition-all duration-300">
            <div class="w-12 h-12 rounded-lg bg-cyan-accent/10 flex items-center justify-center mb-5">
              <FileText class="w-6 h-6 text-cyan-accent" />
            </div>
            <h3 class="text-xl font-semibold mb-2">File Tracking</h3>
            <p class="text-text-secondary leading-relaxed">Every add, edit, and delete with exact line counts. Know exactly which files were created, modified, or removed.</p>
          </div>

          <!-- AI Summary -->
          <div class="group bg-bg-secondary border border-border border-t-2 border-t-transparent hover:border-t-cyan-accent rounded-xl p-6 sm:p-8 hover:border-cyan-accent/30 transition-all duration-300">
            <div class="w-12 h-12 rounded-lg bg-cyan-accent/10 flex items-center justify-center mb-5">
              <Brain class="w-6 h-6 text-cyan-accent" />
            </div>
            <h3 class="text-xl font-semibold mb-2">AI Summary</h3>
            <p class="text-text-secondary leading-relaxed">Plain-English explanation of what changed and why, powered by Claude. Understand the intent, not just the diff.</p>
          </div>

          <!-- Security Scanner -->
          <div class="group bg-bg-secondary border border-border border-t-2 border-t-transparent hover:border-t-cyan-accent rounded-xl p-6 sm:p-8 hover:border-cyan-accent/30 transition-all duration-300">
            <div class="w-12 h-12 rounded-lg bg-cyan-accent/10 flex items-center justify-center mb-5">
              <Shield class="w-6 h-6 text-cyan-accent" />
            </div>
            <h3 class="text-xl font-semibold mb-2">Security Scanner</h3>
            <p class="text-text-secondary leading-relaxed">Automatically catches hardcoded secrets, API keys, and credentials before they hit your repo.</p>
          </div>

          <!-- Shareable Reports -->
          <div class="group bg-bg-secondary border border-border border-t-2 border-t-transparent hover:border-t-cyan-accent rounded-xl p-6 sm:p-8 hover:border-cyan-accent/30 transition-all duration-300">
            <div class="w-12 h-12 rounded-lg bg-cyan-accent/10 flex items-center justify-center mb-5">
              <Share2 class="w-6 h-6 text-cyan-accent" />
            </div>
            <h3 class="text-xl font-semibold mb-2">Shareable Reports</h3>
            <p class="text-text-secondary leading-relaxed">Export as markdown for PRs and Slack. Share a link so your team knows what the AI built.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== WORKS WITH ===== -->
    <section class="py-24 sm:py-32 px-4 sm:px-6 border-t border-border">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">
          Works with <span class="text-cyan-accent">every</span> AI coding tool
        </h2>
        <p class="text-text-secondary mb-16 max-w-lg mx-auto">
          If it uses git, whatdiditdo can track it.
        </p>

        <div class="works-with-grid">
          <div class="works-with-item">
            <div class="w-10 h-10 rounded-lg bg-bg-tertiary flex items-center justify-center">
              <Terminal class="w-5 h-5 text-cyan-accent" />
            </div>
            <span class="font-mono text-sm text-text-primary font-medium">Claude Code</span>
          </div>
          <div class="works-with-connector"></div>
          <div class="works-with-item">
            <div class="w-10 h-10 rounded-lg bg-bg-tertiary flex items-center justify-center">
              <Eye class="w-5 h-5 text-cyan-accent" />
            </div>
            <span class="font-mono text-sm text-text-primary font-medium">Cursor</span>
          </div>
          <div class="works-with-connector"></div>
          <div class="works-with-item">
            <div class="w-10 h-10 rounded-lg bg-bg-tertiary flex items-center justify-center">
              <Github class="w-5 h-5 text-cyan-accent" />
            </div>
            <span class="font-mono text-sm text-text-primary font-medium">Copilot</span>
          </div>
          <div class="works-with-connector"></div>
          <div class="works-with-item">
            <div class="w-10 h-10 rounded-lg bg-bg-tertiary flex items-center justify-center">
              <GitBranch class="w-5 h-5 text-cyan-accent" />
            </div>
            <span class="font-mono text-sm text-text-primary font-medium">Aider</span>
          </div>
          <div class="works-with-connector"></div>
          <div class="works-with-item">
            <div class="w-10 h-10 rounded-lg bg-bg-tertiary flex items-center justify-center">
              <Zap class="w-5 h-5 text-cyan-accent" />
            </div>
            <span class="font-mono text-sm text-text-primary font-medium">Windsurf</span>
          </div>
        </div>

        <!-- + any tool that uses git -->
        <div class="mt-8 inline-flex items-center gap-3 px-6 py-3 bg-cyan-accent/5 border border-cyan-accent/20 rounded-full">
          <ArrowRight class="w-4 h-4 text-cyan-accent" />
          <span class="font-mono text-sm text-cyan-accent font-medium">+ any tool that uses git</span>
        </div>
      </div>
    </section>

    <!-- ===== QUICK START ===== -->
    <section class="py-24 sm:py-32 px-4 sm:px-6 border-t border-border">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">
          Get started in <span class="text-cyan-accent">seconds</span>
        </h2>
        <p class="text-text-secondary text-center max-w-lg mx-auto mb-12">
          Clone, build, run. That's it.
        </p>

        <div class="bg-bg-secondary border border-border rounded-xl overflow-hidden relative group">
          <div class="flex items-center justify-between px-4 py-3 bg-bg-tertiary border-b border-border">
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
              <span class="ml-2 text-xs text-text-muted font-mono">terminal</span>
            </div>
            <button
              id="copy-btn"
              class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-mono text-text-muted hover:text-text-primary bg-bg-secondary hover:bg-bg-tertiary border border-border rounded-md transition-all duration-200"
              aria-label="Copy to clipboard"
            >
              <Copy class="w-3.5 h-3.5 copy-icon" />
              <Check class="w-3.5 h-3.5 check-icon hidden" />
              <span class="copy-label">Copy</span>
            </button>
          </div>
          <div id="code-block" class="p-6 font-mono text-sm leading-loose">
            <div>
              <span class="text-text-muted"># Clone and build</span>
            </div>
            <div>
              <span class="text-text-muted">$</span> <span class="text-cyan-accent">git clone https://github.com/peaktwilight/whatdiditdo</span>
            </div>
            <div>
              <span class="text-text-muted">$</span> <span class="text-cyan-accent">cd whatdiditdo && npm install && npm run build</span>
            </div>
            <div class="mt-4">
              <span class="text-text-muted"># Run in any git repo</span>
            </div>
            <div>
              <span class="text-text-muted">$</span> <span class="text-cyan-accent">node dist/cli.js</span>
            </div>
            <div class="mt-4">
              <span class="text-text-muted"># Skip AI summary (faster)</span>
            </div>
            <div>
              <span class="text-text-muted">$</span> <span class="text-cyan-accent">node dist/cli.js --no-ai</span>
            </div>
            <div class="mt-4">
              <span class="text-text-muted"># Save markdown report</span>
            </div>
            <div>
              <span class="text-text-muted">$</span> <span class="text-cyan-accent">node dist/cli.js --md</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== SOCIAL SHARING ===== -->
    <section class="py-24 sm:py-32 px-4 sm:px-6 border-t border-border">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">
          Share with your <span class="text-cyan-accent">team</span>
        </h2>
        <p class="text-text-secondary mb-8 max-w-lg mx-auto">
          Everyone using AI agents needs this.
        </p>
        <a
          href="https://twitter.com/intent/tweet?text=whatdiditdo%20%E2%80%94%20see%20what%20your%20AI%20coding%20agent%20actually%20changed%20%F0%9F%94%8D%20https://whatdiditdo.doruk.ch"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-3.5 bg-bg-secondary border border-border hover:border-cyan-accent/30 text-text-primary font-semibold rounded-lg transition-all duration-200 hover:scale-[1.02] active:scale-[0.98]"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          Share on X
        </a>
      </div>
    </section>

    <!-- ===== FOOTER ===== -->
    <footer class="py-16 px-4 sm:px-6 border-t border-border">
      <div class="max-w-4xl mx-auto">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8">
          <!-- Left: logo + tagline -->
          <div>
            <a href="/" class="font-mono text-lg font-bold tracking-tight">
              <span class="text-cyan-accent">what</span><span class="text-text-primary">did</span><span class="text-text-secondary">it</span><span class="text-text-primary">do</span>
            </a>
            <p class="text-text-muted text-sm mt-2 max-w-xs">
              Stop blindly trusting your AI agent. See what it actually changed.
            </p>
          </div>
          <!-- Right: links -->
          <div class="flex flex-col gap-3 text-sm">
            <a
              href="https://github.com/peaktwilight/whatdiditdo"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-text-secondary hover:text-cyan-accent transition-colors"
            >
              <Github class="w-4 h-4" />
              peaktwilight/whatdiditdo
            </a>
            <div class="flex items-center gap-3 text-text-muted text-xs font-mono">
              <span>Made by</span>
              <a href="https://github.com/peaktwilight" target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-cyan-accent transition-colors">@peaktwilight</a>
              <span>&middot;</span>
              <a href="https://doruk.ch" target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-cyan-accent transition-colors">doruk.ch</a>
            </div>
            <span class="text-text-muted text-xs font-mono">Free & open source &middot; MIT License</span>
          </div>
        </div>
      </div>
    </footer>

    <!-- ===== SCRIPTS ===== -->
    <script>
      // Copy button
      const copyBtn = document.getElementById('copy-btn');
      const codeBlock = document.getElementById('code-block');
      if (copyBtn && codeBlock) {
        copyBtn.addEventListener('click', async () => {
          const text = codeBlock.innerText
            .split('\n')
            .filter(line => line.startsWith('$'))
            .map(line => line.replace(/^\$\s*/, ''))
            .join('\n');
          await navigator.clipboard.writeText(text);
          copyBtn.querySelector('.copy-icon')?.classList.add('hidden');
          copyBtn.querySelector('.check-icon')?.classList.remove('hidden');
          const label = copyBtn.querySelector('.copy-label');
          if (label) label.textContent = 'Copied!';
          setTimeout(() => {
            copyBtn.querySelector('.copy-icon')?.classList.remove('hidden');
            copyBtn.querySelector('.check-icon')?.classList.add('hidden');
            if (label) label.textContent = 'Copy';
          }, 2000);
        });
      }

      // Stat counter animation on scroll
      const animateCounters = () => {
        const stats = document.querySelectorAll('.stat-number');
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              const finalText = el.textContent || '';
              const target = parseInt(el.dataset.target || '0');
              if (target === 0) return;

              let current = 0;
              const duration = 1500;
              const steps = 40;
              const increment = target / steps;
              const stepTime = duration / steps;

              const suffix = finalText.includes('M') ? 'M+' : '';
              const useComma = finalText.includes(',');

              const timer = setInterval(() => {
                current += increment;
                if (current >= target) {
                  el.textContent = finalText;
                  clearInterval(timer);
                } else {
                  const val = Math.floor(current);
                  if (useComma) {
                    el.textContent = val.toLocaleString();
                  } else {
                    el.textContent = val + suffix;
                  }
                }
              }, stepTime);

              observer.unobserve(el);
            }
          });
        }, { threshold: 0.5 });

        stats.forEach(stat => observer.observe(stat));
      };

      animateCounters();
    </script>

  </body>
</html>
